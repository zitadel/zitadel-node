{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.10.7/.schema/devbox.schema.json",
  "packages": ["nodejs@22", "lefthook@latest"],
  "env": {
    "NPM_CONFIG_CACHE": "/tmp/devbox-npm-cache"
  },
  "shell": {
    "init_hook": ["lefthook install", "npm ci --no-progress"],
    "scripts": {
      "format": ["npm run format"],
      "test": ["npm run test"],
      "check": ["npm run lint"],
      "replit": [
        "docker build --tag node-repl --file Dockerfile .",
        "docker run --rm --interactive --tty node-repl"
      ],
      "docgen": ["npm run docgen"]
    }
  }
}
