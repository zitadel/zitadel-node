{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"outDir": "../dist/out-tsc",
		"declaration": true,
		"types": [
			"node"
		]
	},
	"include": [
		"src/**/*.js",
		"src/**/*.jsx",
		"src/**/*.ts",
		"src/**/*.tsx"
	],
	"exclude": [
		"**/*.spec.ts",
		"**/*.test.ts",
		"**/*.spec.tsx",
		"**/*.test.tsx",
		"**/*.spec.js",
		"**/*.test.js",
		"**/*.spec.jsx",
		"**/*.test.jsx",
		"jest.config.ts",
		"src/**/*.spec.ts",
		"src/**/*.test.ts"
	]
}
