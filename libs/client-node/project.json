{
	"name": "client-node",
	"$schema": "../../node_modules/nx/schemas/project-schema.json",
	"sourceRoot": "libs/client-node/src",
	"projectType": "library",
	"tags": [],
	"targets": {
		"build": {
			"executor": "@nx/js:tsc",
			"outputs": ["{options.outputPath}"],
			"options": {
				"outputPath": "dist/libs/client-node",
				"main": "libs/client-node/src/index.ts",
				"tsConfig": "libs/client-node/tsconfig.lib.json",
				"assets": ["libs/client-node/*.md"]
			}
		},
		"test": {
			"executor": "@nx/jest:jest",
			"outputs": [
				"{workspaceRoot}/coverage/{projectRoot}"
			],
			"options": {
				"jestConfig": "libs/client-node/jest.config.mjs"
			}
		},
		"lint": {
			"executor": "@nx/eslint:lint",
			"options": {
				"eslintConfig": "libs/client-node/eslint.config.mjs"
			}
		}
	}
}
